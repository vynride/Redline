# Redline backend configuration — copy to .env and fill in.
# NEVER commit the real .env.

# --- App ---
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Dev (docker-compose.yml) runs a bundled Postgres `db` service: use a URL whose
# password MATCHES POSTGRES_PASSWORD below (the `db` container reads it from here).
DATABASE_URL=postgresql+psycopg2://redline:CHANGE_ME_STRONG@db:5432/redline
POSTGRES_PASSWORD=CHANGE_ME_STRONG
#
# Prod (docker-compose.prod.yml) has NO bundled db — the backend joins the external
# `backend` network and connects to a Postgres already running there. Point
# DATABASE_URL at that host (POSTGRES_PASSWORD is unused there), e.g.:
#   DATABASE_URL=postgresql+psycopg2://redline:STRONG_PW@<postgres-host>:5432/redline
#
# Bare-host dev (no Docker) uses the app's built-in SQLite default; to use it, comment
# the DATABASE_URL line above (or set it to sqlite:///./redline.db).

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OAuth ---
# Backend base URL used to build provider callback URLs. Must match the
# Authorized redirect URI registered with each provider:
#   {OAUTH_REDIRECT_BASE}/api/auth/google/callback
#   {OAUTH_REDIRECT_BASE}/api/auth/github/callback
OAUTH_REDIRECT_BASE=http://localhost:8000
# Frontend origin the browser is sent back to after login.
FRONTEND_URL=http://localhost:3000

# Google: https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers (New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Sarvam (LLM + STT + TTS, one key) ---
# Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Chat (Sarvam's OpenAI-compatible endpoint)
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_CHAT_MODEL=sarvam-30b
# Output-token ceiling per completion (reasoning + answer share it). 4096 = starter-tier max.
SARVAM_MAX_TOKENS=4096
# Reasoning budget for sarvam-30b. Unbounded, "thinking" eats the whole token budget and
# truncates the JSON. "low" reasons enough for these tasks while leaving room for the answer.
# (low | medium | high | empty to disable)
SARVAM_REASONING_EFFORT=low

# Speech-to-text (Saaras, streaming WebSocket)
SARVAM_STT_WS_URL=wss://api.sarvam.ai/speech-to-text-translate/ws
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=en-IN

# Text-to-speech (Bulbul, streaming WebSocket)
SARVAM_TTS_WS_URL=wss://api.sarvam.ai/text-to-speech/ws
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_DEFAULT_SPEAKER=aditya
SARVAM_TTS_SAMPLE_RATE=24000
