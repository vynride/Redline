# Root .env — read by `docker compose` for ${VAR} interpolation in the compose files.
# Copy to `.env` (never commit it) on the server. App/third-party secrets live
# separately in backend/.env.

# Postgres password. Used by the db service and built into the backend's
# DATABASE_URL. Required by docker-compose.prod.yml; defaults to "redline" for
# local docker-compose.yml.
POSTGRES_PASSWORD=change-me-to-a-strong-random-string
